{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "javascript": {
    "globals": ["Bun", "BUILD_VERSION", "BUILD_TIME"]
  },
  "overrides": [
    {
      "includes": ["voice/recordAudio.ts", "voice/voiceMode.ts"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
